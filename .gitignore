# =============================================================================
# OneHealth Digital Passport Platform — Root .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Frontend build artifacts & dependency trees
# ---------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
build/
.next/
out/
.nuxt/
.vuepress/dist/
.serverless/
.parcel-cache/

# ---------------------------------------------------------------------------
# Frontend environment & secret files
# ---------------------------------------------------------------------------
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---------------------------------------------------------------------------
# Frontend tooling caches
# ---------------------------------------------------------------------------
.eslintcache
.stylelintcache
*.tsbuildinfo
.turbo/

# ---------------------------------------------------------------------------
# Package manager lock files (keep package-lock.json / yarn.lock but ignore
# platform-specific caches)
# ---------------------------------------------------------------------------
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
.pnpm-debug.log*

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# IDE / Editor settings
# ---------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------------------------------------------------------------------------
# OS artifacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Docker local override files (project Dockerfiles are committed)
# ---------------------------------------------------------------------------
docker-compose.override.yml
.docker/
.vagrant/

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
*.bak
*.tmp
*.orig
.cache/
