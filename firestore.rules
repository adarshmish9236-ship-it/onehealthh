rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Platform feedback is readable/writable by authenticated users
    match /platform_feedback/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Users profile and metadata
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Health records and medications isolated by patient_uid
    match /records/{recordId} {
      allow read: if request.auth != null && (resource.data.patient_uid == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor');
      allow write: if request.auth != null && request.resource.data.patient_uid == request.auth.uid;
    }
    
    match /medications/{medId} {
      allow read: if request.auth != null && (resource.data.patient_uid == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor');
      allow write: if request.auth != null && request.resource.data.patient_uid == request.auth.uid;
    }
    
    match /emergency_shares/{shareId} {
      // Accessible with the share token logic
      allow read: if true;
      allow write: if request.auth != null && request.resource.data.patient_uid == request.auth.uid;
    }
    
    match /{document=**} {
      // Deny by default
      allow read, write: if false;
    }
  }
}
